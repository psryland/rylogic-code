# Keep lib/ structure for NuGet local package sources (must come after Debug/Release rules)
lib/*
!lib/readme.txt
!lib/packages/
lib/packages/*
!lib/packages/.gitkeep
!lib/packages/debug/
lib/packages/debug/*
!lib/packages/debug/.gitkeep
!lib/packages/release/
lib/packages/release/*
!lib/packages/release/.gitkeep

