<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
  Globals
  -->
  <PropertyGroup Label="Globals">
    <ConfigurationType>Application</ConfigurationType>
    <VCProjectVersion>16.0</VCProjectVersion>
    <ProjectGuid>{F000F1BC-2B9A-4F9F-8E43-6A0DC9A27EB4}</ProjectGuid>
    <RootNamespace>code_sync</RootNamespace>
    <ProjectName>code_sync</ProjectName>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <!--
  Property Sheets
  -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <Import Project="$(PropsPath)build_configurations.props" />
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <Import Project="$(PropsPath)app.props" />
  <!--
  Build options
  -->
  <ItemDefinitionGroup>
    <ClCompile>
      <EnableModules>false</EnableModules>
      <LanguageStandard>stdcpplatest</LanguageStandard>
      <AdditionalIncludeDirectories>
        ;$(ProjectDir)
        ;%(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
    </Link>
  </ItemDefinitionGroup>
  <!--
  Files
  -->
  <ItemGroup>
    <ClCompile Include="src\main.cpp" />
    <ClInclude Include="src\forward.h" />
    <ClInclude Include="src\code_sync.h" />
  </ItemGroup>
  <!--
  Deploy
  -->
  <Target Name="DeployCodeSync" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <Exec Command="fc /b &quot;$(TargetPath)&quot; &quot;$(RylogicRoot)tools\code_sync\code_sync.exe&quot; >nul 2>&amp;1" IgnoreExitCode="true" ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="FileCompareExitCode" />
    </Exec>
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(RylogicRoot)tools\code_sync\code_sync.exe" Condition="'$(FileCompareExitCode)' != '0'" />
    <Message Text="'code_sync.exe' deployed to tools directory" Importance="high" Condition="'$(FileCompareExitCode)' != '0'" />
  </Target>
  <Target Name="Deploy" DependsOnTargets="DeployCodeSync" />
  <!--
  Targets
  -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
